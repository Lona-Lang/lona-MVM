#[extern "C"]
def __mvm_array_malloc[T](element_count usize) T[*]

#[extern "C"]
def __mvm_array_length[T](payload T[*]) usize

def main() i32 {
    var values = __mvm_array_malloc[u32](4_usize)
    if values == null {
        ret 10
    }
    if __mvm_array_length[u32](values) != 4_usize {
        ret 11
    }
    values(0) = 21_u32
    values(3) = 34_u32
    if values(0) != 21_u32 || values(3) != 34_u32 {
        ret 12
    }
    ret 0
}

ret main()

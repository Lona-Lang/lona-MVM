#[extern "C"]
def __mvm_array_malloc(element_size usize, element_count usize, alignment usize) u8[*]

#[extern "C"]
def __mvm_array_length(payload u8[*]) usize

def main() i32 {
    var values = __mvm_array_malloc(sizeof[u8](), 8192_usize, 1_usize)
    if values == null {
        ret 10
    }

    if __mvm_array_length(values) != 8192_usize {
        ret 11
    }

    ret 0
}

ret main()

#[extern "C"]
def __mvm_array_malloc[T](element_count usize) T[*]

#[extern "C"]
def __mvm_array_length[T](payload T[*]) usize

def main() i32 {
    var values = __mvm_array_malloc[u8](8192_usize)
    if values == null {
        ret 10
    }

    if __mvm_array_length[u8](values) != 8192_usize {
        ret 11
    }

    ret 0
}

ret main()

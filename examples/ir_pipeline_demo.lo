#[extern "C"]
def __mvm_array_malloc[T](element_count usize) T[*]

def read_last(values u32[*]) u32 {
    ret values(3)
}

def main() i32 {
    var values = __mvm_array_malloc[u32](4_usize)
    if values == null {
        ret 10
    }

    values(3) = 99_u32
    var observed = read_last(values)

    if observed != 99_u32 {
        ret 11
    }
    ret 0
}

ret main()
